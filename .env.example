# ═══════════════════════════════════════════════════════════════════════════════
# LLM Provider: "deepseek" | "openai" | "anthropic" | "ollama"
# ═══════════════════════════════════════════════════════════════════════════════
LLM_PROVIDER=deepseek

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# OpenAI API (alternative)
# OPENAI_API_KEY=sk-your-openai-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# Anthropic API (alternative)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama 本地模型 (alternative)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=qwen2.5:7b

# ═══════════════════════════════════════════════════════════════════════════════
# Model Parameters
# ═══════════════════════════════════════════════════════════════════════════════
TEMPERATURE=0.7
MAX_TOKENS=4096
STREAMING=true

# ═══════════════════════════════════════════════════════════════════════════════
# Memory & Vector Store (ChromaDB)
# ═══════════════════════════════════════════════════════════════════════════════
DATA_DIR=./data
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=health_memory
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
SHORT_TERM_MEMORY_LIMIT=20
VECTOR_MEMORY_TOP_K=5

# ═══════════════════════════════════════════════════════════════════════════════
# Observability — Langfuse (optional, set LANGFUSE_ENABLED=true to enable)
# ═══════════════════════════════════════════════════════════════════════════════
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ═══════════════════════════════════════════════════════════════════════════════
# MCP (Model Context Protocol)
# ═══════════════════════════════════════════════════════════════════════════════
MCP_ENABLED=true
MCP_HEALTH_KNOWLEDGE_SERVER=http://localhost:8001

# ═══════════════════════════════════════════════════════════════════════════════
# Resilience & Middleware
# ═══════════════════════════════════════════════════════════════════════════════
MAX_RETRIES=3
RETRY_BACKOFF=2.0
RETRY_MAX_DELAY=60.0
REQUEST_TIMEOUT=120.0
RATE_LIMIT_PER_MINUTE=30

# ═══════════════════════════════════════════════════════════════════════════════
# Agent Configuration
# ═══════════════════════════════════════════════════════════════════════════════
AGENT_MAX_TOOL_ROUNDS=5
AGENT_REFLECTION_ENABLED=true
AGENT_CONFIDENCE_THRESHOLD=0.6
AGENT_PARALLEL_EXECUTION=true

# ═══════════════════════════════════════════════════════════════════════════════
# API Server
# ═══════════════════════════════════════════════════════════════════════════════
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
CORS_ORIGINS=*

# ═══════════════════════════════════════════════════════════════════════════════
# Feature Flags
# ═══════════════════════════════════════════════════════════════════════════════
FEATURE_RAG=true
FEATURE_MCP=true
FEATURE_STREAMING=true
FEATURE_EVALUATION=true

# ═══════════════════════════════════════════════════════════════════════════════
# Logging
# ═══════════════════════════════════════════════════════════════════════════════
LOG_LEVEL=INFO
LOG_FORMAT=text
# LOG_FILE=./logs/app.log
